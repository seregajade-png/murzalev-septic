# Copy to .env.local (dev) or .env (prod) and fill in

# Site URL — used for sitemap, OG tags, JSON-LD
NEXT_PUBLIC_SITE_URL=https://murzalev.ru

# Telegram bot notifications for /api/lead
# 1. Create bot via @BotFather, get TOKEN
# 2. Start chat with bot, send /start
# 3. Get your chat_id: curl "https://api.telegram.org/bot<TOKEN>/getUpdates"
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
